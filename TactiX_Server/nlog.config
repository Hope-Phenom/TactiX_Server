<?xml version="1.0" encoding="utf-8"?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true">

    <!-- 启用异步写入提升性能 -->
    <targets async="true">

        <!-- 控制台输出 (开发环境) -->
        <target name="console" xsi:type="ColoredConsole"
                layout="${longdate} | ${level:uppercase=true:padding=5} | ${logger:shortName=true} | ${message} ${exception:format=toString}" />

        <!-- 按文件大小滚动 + 按日期归档 (组合策略) -->
        <target name="rollingFile" xsi:type="File"
                fileName="logs/app-${shortdate}.log"
                archiveFileName="logs/app-${shortdate}-{#####}.log"
                archiveAboveSize="10485760"
                archiveNumbering="Sequence"
                maxArchiveFiles="10"
                layout="${longdate} | ${level:uppercase=true:padding=5} | ${logger} | ${message} ${exception:format=toString}" />

    </targets>

    <rules>
        <!-- 忽略Microsoft基础日志 -->
        <logger name="Microsoft.*" minlevel="Info" final="true" />
        <logger name="System.*" minlevel="Info" final="true" />

        <!-- 所有日志 -->
        <logger name="*" minlevel="Debug" writeTo="dailyFile,rollingFile,jsonFile" />

        <!-- 控制台仅显示Info及以上 -->
        <logger name="*" minlevel="Info" writeTo="console" />
    </rules>
</nlog>